---
import AdminPortal from '../components/AdminPortal.jsx'
import PageShell from '../components/astro/PageShell.astro'
import BaseLayout from '../layouts/BaseLayout.astro'
import { getCanonical } from '../lib/seo.js'

const path = '/admin'
---

<BaseLayout
  title="Admin Portal | Fidara Group"
  description="Internal Fidara admin dashboard for monitoring client documents, billing, and requests."
  canonical={getCanonical(path)}
  robots="noindex,nofollow"
>
  <PageShell active="">
    <section class="border-t border-stone-200 bg-slate-50/70 px-6 py-10 sm:px-8 sm:py-12">
      <div class="mx-auto max-w-7xl">
        <AdminPortal client:load />
      </div>
    </section>
  </PageShell>
</BaseLayout>
