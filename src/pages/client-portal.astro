---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getCanonical } from '../lib/seo.js'

const target = '/login'
---

<BaseLayout
  title="Portal Login Redirect | Lydia Financial"
  description="This legacy client portal link now redirects to Lydia Financial's secure portal login for private document access."
  canonical={getCanonical(target)}
  robots="noindex,nofollow"
>
  <main id="main-content" class="min-h-screen bg-[#f7f3eb] px-8 py-24 text-slate-900">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="font-serif text-4xl leading-tight text-slate-900">Redirecting to portal login.</h1>
      <p class="mt-4 text-base leading-7 text-slate-700">
        The previous client portal link has moved. You are being sent to the current secure login page.
      </p>
      <p class="mt-6">
        <a href={target} class="text-sm font-medium text-emerald-700 underline underline-offset-4">Continue to portal login</a>
      </p>
    </div>
  </main>

  <meta http-equiv="refresh" content={`0;url=${target}`} />
  <script is:inline define:vars={{ target }}>
    window.location.replace(target);
  </script>
</BaseLayout>
