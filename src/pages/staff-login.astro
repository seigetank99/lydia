---
import StaffLoginForm from '../components/StaffLoginForm.jsx'
import PageHero from '../components/astro/PageHero.astro'
import PageShell from '../components/astro/PageShell.astro'
import BaseLayout from '../layouts/BaseLayout.astro'
import { getCanonical } from '../lib/seo.js'

const path = '/staff-login'
---

<BaseLayout
  title="Staff Login | Lydia Financial"
  description="Secure access for Lydia Financial team members to verify staff credentials before opening the protected admin dashboard."
  canonical={getCanonical(path)}
  robots="noindex,nofollow"
>
  <PageShell active="">
    <PageHero
      eyebrow="Staff Login"
      title="Staff Login"
      description="Secure access for Lydia Financial team members."
    />

    <section class="border-t border-stone-200 px-8 py-12">
      <div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-[minmax(0,1.1fr)_minmax(360px,480px)] lg:items-start">
        <div class="rounded-xl border border-stone-200 bg-white/70 p-8 shadow-sm">
          <h2 class="font-serif text-3xl leading-tight text-slate-900">Protected admin access</h2>
          <p class="mt-4 text-sm leading-7 text-slate-700">
            Staff credentials are verified through Supabase Auth, then checked against Lydia Financial admin role permissions before the dashboard opens.
          </p>
        </div>

        <StaffLoginForm client:load />
      </div>
    </section>
  </PageShell>
</BaseLayout>
