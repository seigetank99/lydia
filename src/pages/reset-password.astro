---
import ResetPasswordForm from '../components/ResetPasswordForm.jsx'
import PageHero from '../components/astro/PageHero.astro'
import PageShell from '../components/astro/PageShell.astro'
import BaseLayout from '../layouts/BaseLayout.astro'
import { getCanonical } from '../lib/seo.js'

const path = '/reset-password'
---

<BaseLayout
  title="Reset Password | Lydia Financial"
  description="Choose a new password for your Lydia Financial client portal account after opening a secure Supabase Auth reset email link."
  canonical={getCanonical(path)}
  robots="noindex,nofollow"
>
  <PageShell active="">
    <PageHero
      eyebrow="Client Portal"
      title="Choose a new password"
      description="Use the reset link from your email, then enter a new password for your portal account."
    />

    <section class="border-t border-stone-200 px-8 py-12">
      <div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-[minmax(0,1.1fr)_minmax(360px,480px)] lg:items-start">
        <div class="rounded-xl border border-stone-200 bg-white/70 p-8 shadow-sm">
          <h2 class="font-serif text-3xl leading-tight text-slate-900">Protect your client portal</h2>
          <p class="mt-4 text-sm leading-7 text-slate-700">
            Use a unique password with at least 8 characters. Contact Lydia Financial if you did not request this reset.
          </p>
        </div>

        <ResetPasswordForm client:load />
      </div>
    </section>
  </PageShell>
</BaseLayout>
