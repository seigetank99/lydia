---
import LoginForm from '../components/LoginForm.jsx'
import PageHero from '../components/astro/PageHero.astro'
import PageShell from '../components/astro/PageShell.astro'
import BaseLayout from '../layouts/BaseLayout.astro'
import { getCanonical } from '../lib/seo.js'

const path = '/login'
---

<BaseLayout
  title="Client Portal Login | Lydia Financial"
  description="Secure Lydia Financial client portal login for document uploads, file access, and private document exchange."
  canonical={getCanonical(path)}
  robots="noindex,nofollow"
>
  <PageShell active="">
    <PageHero
      eyebrow="Client Portal"
      title="Client Portal Login"
      description="Access your secure Lydia Financial workspace to upload and retrieve documents."
    />

    <section class="border-t border-stone-200 px-8 py-12">
      <div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-[minmax(0,1.1fr)_minmax(360px,480px)] lg:items-start">
        <div class="rounded-xl border border-stone-200 bg-white/70 p-8 shadow-sm">
          <h2 class="font-serif text-3xl leading-tight text-slate-900">Secure document exchange</h2>
          <p class="mt-4 text-sm leading-7 text-slate-700">
            Use your portal credentials to upload tax files, bookkeeping records, payroll documents, and other requested items.
          </p>
          <div class="mt-6 grid gap-3">
            {['Private document storage', 'Access limited to your linked client account', 'Direct download links for existing files'].map((item) => (
              <div class="flex items-start gap-3 text-sm leading-7 text-slate-700">
                <span class="mt-1 text-emerald-600">✓</span>
                <span>{item}</span>
              </div>
            ))}
          </div>
        </div>

        <LoginForm client:load />
      </div>
    </section>
  </PageShell>
</BaseLayout>
