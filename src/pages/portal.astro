---
import ClientPortalDashboard from '../components/ClientPortalDashboard.jsx'
import PageShell from '../components/astro/PageShell.astro'
import BaseLayout from '../layouts/BaseLayout.astro'
import { getCanonical } from '../lib/seo.js'

const path = '/portal'
---

<BaseLayout
  title="Client Portal | Lydia Financial"
  description="Secure Lydia Financial client portal for uploading requested documents, reviewing submissions, and downloading shared files."
  canonical={getCanonical(path)}
  robots="noindex,nofollow"
>
  <PageShell active="">
    <section class="border-t border-stone-200 bg-slate-50/70 px-6 py-10 sm:px-8 sm:py-12">
      <div class="mx-auto max-w-7xl">
        <ClientPortalDashboard client:load />
      </div>
    </section>
  </PageShell>
</BaseLayout>
