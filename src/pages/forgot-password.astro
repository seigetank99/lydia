---
import ForgotPasswordForm from '../components/ForgotPasswordForm.jsx'
import PageHero from '../components/astro/PageHero.astro'
import PageShell from '../components/astro/PageShell.astro'
import BaseLayout from '../layouts/BaseLayout.astro'
import { getCanonical } from '../lib/seo.js'

const path = '/forgot-password'
---

<BaseLayout
  title="Forgot Password | Fidara Group"
  description="Request a secure Fidara client portal password reset link through Supabase Auth without emailing or exposing passwords."
  canonical={getCanonical(path)}
  robots="noindex,nofollow"
>
  <PageShell active="">
    <PageHero
      eyebrow="Client Portal"
      title="Reset your portal password"
      description="Enter the email address used for your Fidara client portal account."
    />

    <section class="border-t border-stone-200 px-8 py-12">
      <div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-[minmax(0,1.1fr)_minmax(360px,480px)] lg:items-start">
        <div class="rounded-xl border border-stone-200 bg-white/70 p-8 shadow-sm">
          <h2 class="font-serif text-3xl leading-tight text-slate-900">Secure password recovery</h2>
          <p class="mt-4 text-sm leading-7 text-slate-700">
            If the email matches a portal account, Supabase Auth will send a time-limited reset link. Fidara will never email you a password.
          </p>
        </div>

        <ForgotPasswordForm client:load />
      </div>
    </section>
  </PageShell>
</BaseLayout>
