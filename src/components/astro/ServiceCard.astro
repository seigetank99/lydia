---
const { title, description, image, slug } = Astro.props
---

<a
  href={`/services/${slug}`}
  class="group rounded-xl border border-stone-200 bg-white/60 p-6 text-center shadow-sm transition hover:-translate-y-1 hover:bg-white hover:shadow-md"
>
  <img
    src={image}
    alt={title}
    class="mx-auto mb-4 h-20 w-20 object-contain mix-blend-multiply"
  />

  <h3 class="font-serif text-xl text-slate-900">{title}</h3>

  <p class="mt-2 text-sm leading-5 text-slate-700">{description}</p>
  <span class="mt-4 inline-flex items-center gap-2 text-xs font-medium text-emerald-700">
    Learn more
    <span aria-hidden="true" class="transition group-hover:translate-x-1">→</span>
  </span>
</a>
