---
import { siteConfig } from '../site-core/data/index.jsx'
---

<footer class="border-t border-cedar/10 py-16">
  <div class="mx-auto max-w-5xl px-6">
    <div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-4">
      <div class="space-y-4 sm:col-span-2">
        <span class="font-serif text-xl text-cedar">Lydia</span>
        <p class="max-w-[30ch] text-sm text-cedar/55">
          Financial advisory rooted in principle. Serving the dreamers and doers of the small business community.
        </p>
      </div>

      <div class="space-y-4">
        <h4 class="text-[10px] font-semibold uppercase tracking-widest text-moss">Navigation</h4>
        <div class="flex flex-col gap-2">
          <a href="/about" class="text-sm text-cedar/75 transition-colors hover:text-cedar">About</a>
          <a href="/our-values" class="text-sm text-cedar/75 transition-colors hover:text-cedar">Our Values</a>
          <a href="/services" class="text-sm text-cedar/75 transition-colors hover:text-cedar">Services</a>
          <a href="/contact" class="text-sm text-cedar/75 transition-colors hover:text-cedar">Contact</a>
        </div>
      </div>

      <div class="space-y-4">
        <h4 class="text-[10px] font-semibold uppercase tracking-widest text-moss">Contact</h4>
        <div class="flex flex-col gap-2">
          <a href={`mailto:${siteConfig.email}`} class="text-sm text-cedar/75 transition-colors hover:text-cedar">{siteConfig.email}</a>
          <a href={`tel:${siteConfig.phone}`} class="text-sm text-cedar/75 transition-colors hover:text-cedar">(516) 646-1015</a>
          <p class="text-sm text-cedar/75">Mon - Fri: 9am - 5pm</p>
        </div>
      </div>
    </div>

    <div class="mt-16 flex flex-col justify-between gap-2 border-t border-cedar/10 pt-8 sm:flex-row">
      <p class="text-[10px] font-medium uppercase tracking-widest text-cedar/45">
        © 2026 Lydia Financial LLC
      </p>
      <div class="flex items-center gap-4">
        <a href="/staff-login" class="text-[10px] font-medium uppercase tracking-widest text-cedar/45 transition-colors hover:text-cedar">
          Staff Login
        </a>
        <p class="text-[10px] font-medium uppercase tracking-widest text-cedar/45">Stewardship first</p>
      </div>
    </div>
  </div>
</footer>
