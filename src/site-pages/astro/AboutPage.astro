---
import PageShell from '../../components/astro/PageShell.astro'

const served = [
  [
    'Kingdom-minded entrepreneurs',
    'Assisting business owners who want to grow profitable companies while operating with integrity and generosity.',
    'M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 0 0 .75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 0 0-3.413-.387m4.416 0a48.765 48.765 0 0 0-3.414.387m-4.416 0a48.765 48.765 0 0 0-3.414-.387m4.416 0a48.114 48.114 0 0 0-3.413.387',
  ],
  [
    'Values-driven professionals',
    'Providing meticulous accounting and advisory services to individuals and families who seek alignment between their finances and their convictions.',
    'M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z',
  ],
]

const reasons = [
  ['Stewardship', 'You know your business and want the back office support, no fuss.'],
  ['Plain talk', 'We explain the accounting, tax, and financial mumbo jumbo in plain talk. No Tower of Babel here.'],
  ['Christ focus', 'Our Christian work ethic is coupled with God centered wisdom.'],
]
---

<PageShell active="about">
  <section class="py-20 sm:py-32">
    <div class="mx-auto max-w-5xl px-6">
      <h1 class="max-w-[18ch] text-balance font-serif text-4xl leading-tight tracking-tight text-cedar sm:text-6xl">
        Your Accounting, Tax, and Financial Advisory Needs in Trusted Hands.
      </h1>
      <p class="font-signature text-pretty mt-6 max-w-[60ch] text-2xl leading-relaxed text-cedar/75 sm:text-3xl">
        You build the widgets, we've got your back...office.
      </p>
      <p class="text-pretty mt-4 max-w-[64ch] text-base leading-relaxed text-cedar/75 sm:text-lg">
        We bring bookkeeping, tax preparation, M&A advisory, and fractional CFO support to your business, grounded in our Christian values of hard work, integrity, and trust.
      </p>
    </div>
  </section>

  <section class="border-y border-cedar/10 bg-cedar/5 py-20 sm:py-28">
    <div class="mx-auto max-w-5xl px-6">
      <div class="max-w-3xl space-y-6">
        <h2 class="font-serif text-3xl text-cedar">The Lydia Story</h2>
        <p class="text-pretty text-base leading-relaxed text-cedar/75">Our foundation is drawn from the Biblical account of Lydia of Thyatira, found in the Book of Acts. Lydia was a prominent first-century entrepreneur and a dealer in purple cloth, a luxury commodity of the ancient world.</p>
        <p class="text-pretty text-base leading-relaxed text-cedar/75">More than just a successful merchant, Lydia was a devoted leader who opened her heart to God's purpose and her home to others. She proved that deep faith and high-level business acumen go hand in hand.</p>
        <p class="text-pretty text-base leading-relaxed text-cedar/75">At Lydia, we draw inspiration from her legacy, merging technical excellence with a heart for service to help clients build thriving, sustainable, purpose-driven organizations.</p>
        <p class="text-pretty text-base leading-relaxed text-cedar/75">The name reminds us that business can be both capable and generous. We believe financial service should bring order, honesty, and peace of mind without losing sight of the people behind the numbers.</p>
      </div>
    </div>
  </section>

  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-5xl px-6">
      <div class="grid gap-12 sm:grid-cols-2">
        <article class="space-y-5">
          <span class="font-bree text-3xl text-cedar sm:text-4xl">Mission</span>
          <p class="font-signature text-2xl leading-snug text-cedar sm:text-3xl">
            Helping businesses and people honor God through honest, practical, Christ-centered accounting, tax, financial, and business advisory services.
          </p>
        </article>
        <article class="space-y-5">
          <span class="font-bree text-3xl text-cedar sm:text-4xl">Vision</span>
          <p class="font-signature text-2xl leading-snug text-cedar sm:text-3xl">
            A community where businesses and individuals prosper responsibly, while experiencing God's love in all they do.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="border-y border-cedar/10 bg-cedar/5 py-24 sm:py-32">
    <div class="mx-auto max-w-5xl px-6">
      <div class="grid gap-12 sm:grid-cols-[0.8fr_1.2fr]">
        <div>
          <h2 class="font-serif text-3xl text-cedar">What We Believe</h2>
          <p class="mt-6 text-pretty text-base leading-relaxed text-cedar/75">
            We believe financial clarity is a form of care. Clean books, thoughtful tax planning, clear systems, and wise advice help owners make better decisions with less pressure.
          </p>
        </div>
        <div class="grid gap-5 sm:grid-cols-2">
          <article class="rounded-xl bg-sand p-6 ring-1 ring-cedar/10">
            <h3 class="font-medium text-cedar">Professional and personal</h3>
            <p class="mt-3 text-sm leading-relaxed text-cedar/75">Clients should feel known, respected, and supported by people who understand both the technical work and the weight of leadership.</p>
          </article>
          <article class="rounded-xl bg-sand p-6 ring-1 ring-cedar/10">
            <h3 class="font-medium text-cedar">Modern and grounded</h3>
            <p class="mt-3 text-sm leading-relaxed text-cedar/75">We use practical technology and disciplined processes, guided by Christian values rather than trend-driven advice.</p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-5xl px-6">
      <h2 class="mb-12 font-serif text-3xl text-cedar">Whom We Serve</h2>
      <p class="text-pretty mb-10 max-w-[56ch] text-base leading-relaxed text-cedar/75">
        We partner with small business clients and individuals who view their work as a calling and want their financial practices to reflect their values.
      </p>
      <div class="grid gap-10 sm:grid-cols-2">
        {served.map(([title, description, icon]) => (
          <article class="space-y-4">
            <div class="flex size-10 items-center justify-center rounded-lg bg-moss/5 text-moss">
              <svg class="size-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={icon}></path>
              </svg>
            </div>
            <h3 class="font-medium text-cedar">{title}</h3>
            <p class="text-pretty text-sm leading-relaxed text-cedar/75">{description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-5xl px-6">
      <h2 class="mb-16 font-serif text-3xl text-cedar">Why you choose Lydia</h2>
      <div class="grid gap-10 sm:grid-cols-3">
        {reasons.map(([title, description]) => (
          <article class="space-y-3">
            <h3 class="font-signature text-2xl font-medium text-cedar">{title}</h3>
            <p class="text-pretty text-sm leading-relaxed text-cedar/75">{description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</PageShell>
