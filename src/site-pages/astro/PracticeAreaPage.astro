---
import Breadcrumbs from '../../components/astro/Breadcrumbs.astro'
import PageHero from '../../components/astro/PageHero.astro'
import PageShell from '../../components/astro/PageShell.astro'
import RelatedLinksSection from '../../components/astro/RelatedLinksSection.astro'

const { page } = Astro.props
---

<PageShell active="services">
  <Breadcrumbs items={[{ label: 'Practice Areas', href: '/practice-areas' }, { label: page.title }]} />

  <PageHero eyebrow={page.eyebrow} title={page.title} description={page.hero}>
    <div class="mt-8 flex flex-wrap gap-4">
      <a href="/contact" class="rounded-md bg-emerald-600 px-8 py-4 text-sm font-medium text-white transition hover:bg-emerald-700">
        Book a Consultation
      </a>
      <a href="/practice-areas" class="rounded-md border border-emerald-600 px-8 py-4 text-sm font-medium text-slate-900 transition hover:bg-white">
        All Practice Areas
      </a>
    </div>
  </PageHero>

  <section class="border-t border-stone-200 px-8 py-12">
    <div class="mx-auto grid max-w-6xl gap-5 md:grid-cols-3">
      {page.sections.map(([title, content]) => (
        <article class="rounded-xl border border-stone-200 bg-white/60 p-6 shadow-sm">
          <h2 class="font-serif text-3xl leading-tight text-slate-900">{title}</h2>
          {Array.isArray(content) ? (
            <div class="mt-5 grid gap-3">
              {content.map((item) => (
                <div class="flex items-start gap-3">
                  <span class="mt-0.5 h-5 w-5 flex-none text-emerald-600">✓</span>
                  <p class="text-sm leading-6 text-slate-700">{item}</p>
                </div>
              ))}
            </div>
          ) : (
            <p class="mt-5 text-sm leading-7 text-slate-700">{content}</p>
          )}
        </article>
      ))}
    </div>
  </section>

  <RelatedLinksSection
    title="Related Pages"
    links={[
      ...page.related,
      ['Pricing', '/pricing'],
      ['Contact', '/contact'],
    ]}
  />
</PageShell>
