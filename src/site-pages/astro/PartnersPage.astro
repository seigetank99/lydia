---
import { mailto } from '../../components/site-core/data/index.jsx'
import PageHero from '../../components/astro/PageHero.astro'
import PageShell from '../../components/astro/PageShell.astro'

const partners = [
  ['Attorneys', 'Entity, contracts, succession, immigration, and cross-border coordination.'],
  ['Bankers & Lenders', 'Financing, lending packages, cash flow conversations, and reporting support.'],
  ['Insurance Advisors', 'Business risk, benefits, key-person planning, and coverage coordination.'],
  ['Technology Vendors', 'Payroll, accounting, document, cybersecurity, and managed IT platforms.'],
]
---

<PageShell active="about">
  <PageHero eyebrow="Partners" title="A better client experience through trusted professional coordination." description="Lydia Financial can coordinate with attorneys, bankers, insurance advisors, technology vendors, and other professionals around shared client goals.">
    <div class="mt-8 flex flex-wrap gap-4">
      <a href={mailto('Partner inquiry for Lydia Financial', 'Hello Lydia Financial,\n\nI would like to connect about a potential professional partnership.\n\nName:\nFirm / Company:\nRole:\nClient or referral focus:\nBest phone number:\n\nNotes:\n')} class="rounded-md bg-emerald-600 px-8 py-4 text-sm font-medium text-white transition hover:bg-emerald-700">
        Email Lydia Financial
      </a>
      <a href="/referrals" class="rounded-md border border-emerald-600 px-8 py-4 text-sm font-medium text-slate-900 transition hover:bg-white">
        Refer a Client
      </a>
    </div>
  </PageHero>

  <section class="border-t border-stone-200 px-8 py-12">
    <div class="mx-auto grid max-w-6xl gap-5 md:grid-cols-2 lg:grid-cols-4">
      {partners.map(([title, description]) => (
        <article class="rounded-xl border border-stone-200 bg-white/60 p-6 shadow-sm">
          <h3 class="font-serif text-2xl leading-tight text-slate-900">{title}</h3>
          <p class="mt-4 text-sm leading-7 text-slate-700">{description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="border-t border-stone-200 px-8 py-12">
    <div class="mx-auto max-w-6xl rounded-xl border border-stone-200 bg-white/60 p-8 shadow-sm">
      <h2 class="font-serif text-4xl leading-tight text-slate-900">What to include in a partner email</h2>
      <div class="mt-6 grid gap-4 md:grid-cols-3">
        {[
          ['Your role', 'Tell us your firm, specialty, and how you support clients.'],
          ['Client fit', 'Share the type of client or situation you think overlaps with Lydia Financial.'],
          ['Next step', 'Let us know whether you want an introduction, referral process, or coordination conversation.'],
        ].map(([title, description]) => (
          <div class="border-t border-stone-200 pt-4">
            <h3 class="font-serif text-2xl text-slate-900">{title}</h3>
            <p class="mt-3 text-sm leading-7 text-slate-700">{description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</PageShell>
