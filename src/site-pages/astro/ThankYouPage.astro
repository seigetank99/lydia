---
import PageShell from '../../components/astro/PageShell.astro'
---

<PageShell active="contact">
  <section class="border-t border-stone-200 px-8 py-16">
    <div class="mx-auto max-w-5xl rounded-xl border border-emerald-900 bg-emerald-950 p-8 text-white shadow-sm md:p-12">
      <p class="text-xs font-semibold uppercase tracking-[0.35em] text-emerald-100">Request received</p>
      <h1 class="mt-6 max-w-3xl font-serif text-4xl leading-tight md:text-6xl">Thank you. We value the opportunity to earn your business.</h1>
      <p class="mt-6 max-w-2xl text-base leading-8 text-emerald-50">
        Your request has been received by Fidara. One of our team members will review your message and get back to you shortly.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/contact" class="inline-flex rounded-md bg-white px-6 py-3 text-sm font-medium text-emerald-950 transition hover:bg-emerald-50">Add details</a>
        <a href="/" class="inline-flex rounded-md border border-emerald-200 px-6 py-3 text-sm font-medium text-white transition hover:bg-white/10">Return home</a>
      </div>ocuments without a policy.


    </div>
  </section>
</PageShell>
