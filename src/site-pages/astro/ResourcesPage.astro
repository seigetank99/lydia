---
import { resourceArticles } from '../../components/site-core/data/index.jsx'
import PageShell from '../../components/astro/PageShell.astro'
import PageHero from '../../components/astro/PageHero.astro'
---

<PageShell active="resources">
  <PageHero
    eyebrow="Resources"
    title="Plain-English guides for cleaner books, better systems, and stronger decisions."
    description="Use these as placeholder articles now. Later, each card can become a full blog post or downloadable checklist."
    backgroundImage="/images/resource.png"
  />

  <section class="border-t border-stone-200 px-8 py-12">
    <div class="mx-auto grid max-w-6xl gap-5 md:grid-cols-2">
      {resourceArticles.map((resource) => (
        <article class="rounded-xl border border-stone-200 bg-white/60 p-6 shadow-sm transition hover:-translate-y-1 hover:bg-white hover:shadow-md">
          <p class="mb-4 text-xs uppercase tracking-[0.25em] text-emerald-700">
            {resource.category}
          </p>
          <h3 class="font-serif text-3xl leading-tight text-slate-900">
            {resource.title}
          </h3>
          <p class="mt-4 text-sm leading-7 text-slate-700">
            {resource.description}
          </p>
          <a
            href={`/resources/${resource.slug || resource.title.toLowerCase().replaceAll(' ', '-')}`}
            class="mt-5 inline-flex items-center gap-2 text-xs font-medium text-emerald-700"
          >
            Read guide <span aria-hidden="true">→</span>
          </a>
        </article>
      ))}
    </div>
  </section>
</PageShell>
