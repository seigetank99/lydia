---
import PageHero from '../../components/astro/PageHero.astro'
import PageShell from '../../components/astro/PageShell.astro'

const { page } = Astro.props
---

<PageShell active="services">
  <PageHero eyebrow="U.S. Expansion" title={page.title} description={page.description}>
    <div class="mt-8 flex flex-wrap gap-4">
      <a href="/contact" class="rounded-md bg-emerald-600 px-8 py-4 text-sm font-medium text-white transition hover:bg-emerald-700">
        Start the Conversation
      </a>
      <a href="/us-expansion" class="rounded-md border border-emerald-600 px-8 py-4 text-sm font-medium text-slate-900 transition hover:bg-white">
        All U.S. Expansion
      </a>
    </div>
  </PageHero>

  <section class="border-t border-stone-200 px-8 py-12">
    <div class="mx-auto grid max-w-5xl gap-4">
      {page.points.map((point) => (
        <div class="flex items-start gap-4 border-b border-stone-200 pb-4 last:border-b-0">
          <span class="mt-1 h-5 w-5 flex-none text-emerald-600">✓</span>
          <p class="text-base leading-7 text-slate-800">{point}</p>
        </div>
      ))}
    </div>
  </section>
</PageShell>
