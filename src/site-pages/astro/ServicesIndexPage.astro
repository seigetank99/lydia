---
import PageShell from '../../components/astro/PageShell.astro'

const services = [
  {
    title: 'Bookkeeping & Accounting',
    href: '/services/bookkeeping',
    description:
      'Clean, accurate books are the foundation of every good business decision. We organize transactions, reconciliations, documents, and reporting, so that you can charge ahead with numbers you trust.',
    bullets: [
      'Monthly bookkeeping and reconciliation',
      'Financial statement preparation',
      'Tax-ready records',
    ],
    note: 'As an owner who lives and breathes your company 24/7/365, you need clarity from the chaos...reliable records to make decisions which keep your engine humming.',
  },
  {
    title: 'Tax Preparation & Planning',
    href: '/services/tax',
    description: '',
    bullets: ['Entity and individual', 'Entity selection'],
    note: "You gotta file taxes...but you don't want surprises. You expect detailed planning without the fuss.",
    reverse: true,
  },
  {
    title: 'M&A Advisory',
    href: '/services/m-and-a-advisory',
    description:
      'The next big step is M&A. We help buyers and sellers through the entire transaction.',
    bullets: [
      'Preparing your books for due diligence',
      'Quality of Earnings ("QoE") reports',
      'Buyside & sellside',
      'Full due diligence',
      'Financial advisory through closing',
    ],
    note: 'We are shoulder to shoulder with you until the M&A deal closes.',
  },
  {
    title: 'Outsourced CFO',
    href: '/services/cfo-services',
    description:
      "Sometimes you need to bounce ideas off of a strategic advisor. It's what your growing company needs.",
    bullets: ['Financial Planning & Analysis', 'Goal setting', 'Strategy'],
    note: 'Your business is your baby. We bring strategic financial wisdom to help your baby thrive.',
    reverse: true,
  },
]

const steps = [
  ['01', 'Discovery', 'We start with a friendly conversation about your business, your goals, and where you need help.'],
  ['02', 'Plan', 'We create a tailored service plan that fits your needs and your budget: no upselling, no surprises.'],
  ['03', 'Execute', 'We handle the work with diligence and precision, keeping you informed every step of the way.'],
  ['04', 'Measure', 'We meet regularly to review progress, adjust strategy, and ensure your finances support your vision.'],
]
---

<PageShell active="services">
  <section class="py-20 sm:py-32">
    <div class="mx-auto max-w-5xl px-6">
      <h1 class="max-w-[18ch] text-balance font-serif text-4xl leading-tight tracking-tight text-cedar sm:text-6xl">
        Accounting, Tax, M&A advisory, Outsourced CFO support built with conviction.
      </h1>
      <p class="text-pretty mt-6 max-w-[56ch] text-base leading-relaxed text-cedar/75 sm:text-lg">
        From monthly bookkeeping to tax preparation, outsourced CFO guidance, and transaction readiness, we provide the practical infrastructure small business owners need to thrive.
      </p>
    </div>
  </section>

  <section class="border-y border-cedar/10 bg-cedar/5 py-24 sm:py-32">
    <div class="mx-auto max-w-5xl space-y-24 px-6">
      {services.map((service) => (
        <div class="grid items-start gap-12 sm:grid-cols-2">
          <div class={`space-y-6 ${service.reverse ? 'sm:order-2' : ''}`}>
            <h2 class="font-serif text-3xl text-cedar">{service.title}</h2>
            {service.description && <p class="text-pretty text-base leading-relaxed text-cedar/75">{service.description}</p>}
            <ul class="space-y-3 text-sm text-cedar/75">
              {service.bullets.map((item) => (
                <li class="flex items-start gap-3">
                  <span class="mt-1.5 block h-1 w-1 shrink-0 rounded-full bg-cedar"></span>
                  {item}
                </li>
              ))}
            </ul>
            <a href={service.href} class="inline-flex text-sm font-medium text-cedar underline underline-offset-4">Learn more</a>
          </div>
          <aside class={`pt-2 ${service.reverse ? 'sm:order-1' : ''}`}>
            <div class="space-y-4">
              <p class={`text-xl text-cedar ${service.title === 'Bookkeeping & Accounting' ? 'font-signature sm:text-2xl' : 'font-serif italic'}`}>{service.note}</p>
            </div>
          </aside>
        </div>
      ))}
    </div>
  </section>

  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-5xl px-6">
      <h2 class="mb-16 font-serif text-3xl text-cedar">How we work together</h2>
      <div class="grid gap-10 sm:grid-cols-4">
        {steps.map(([number, title, description]) => (
          <article class="space-y-4">
            <span class="font-serif text-4xl text-cedar/20">{number}</span>
            <h3 class="font-medium text-cedar">{title}</h3>
            <p class="text-pretty text-sm leading-relaxed text-cedar/75">{description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</PageShell>
