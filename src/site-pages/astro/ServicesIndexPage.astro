---
import PageShell from '../../components/astro/PageShell.astro'

const services = [
  {
    number: '01',
    title: 'Bookkeeping Services',
    href: '/services/bookkeeping',
    description:
      'Clean, accurate books are the foundation of every good business decision. We organize transactions, reconciliations, documents, and reporting so you can lead from numbers you trust.',
    bullets: [
      'Monthly bookkeeping and reconciliation',
      'Financial statement preparation',
      'Receipt and document organization',
      'Tax-ready records and monthly close support',
    ],
    note: 'Best for owners who want less chaos, cleaner records, and a reliable financial rhythm.',
  },
  {
    number: '02',
    title: 'Tax Services',
    href: '/services/tax',
    description:
      'Tax season should not be a panic. We help individuals, families, and business owners prepare earlier, understand deadlines, and make thoughtful planning decisions.',
    bullets: [
      'Individual and business tax preparation where scoped',
      'Quarterly estimated tax planning',
      'Entity and owner compensation coordination',
      'Tax-readiness support connected to clean books',
    ],
    note: 'Best for clients who want proactive clarity, fewer surprises, and plain-English tax guidance.',
    reverse: true,
  },
  {
    number: '03',
    title: 'CFO Advisory Services',
    href: '/services/cfo-services',
    description:
      'Growing businesses need strategic financial guidance, but not always a full-time CFO. We step in as your financial partner, providing the insight you need at a scale that fits.',
    bullets: [
      'Cash flow forecasting and management',
      'Budgeting and financial goal-setting',
      'Growth strategy and expansion planning',
      'Monthly or quarterly business review meetings',
    ],
    note: 'Best for owners making decisions around hiring, pricing, cash flow, debt, or expansion.',
  },
  {
    number: '04',
    title: 'Managed IT Services',
    href: '/services/managed-it-services',
    description:
      'Modern businesses depend on secure, organized technology. We help protect the systems behind accounting, payroll, documents, users, devices, and daily operations.',
    bullets: [
      'User access and offboarding workflows',
      'Device, backup, and vendor coordination',
      'Cybersecurity basics and support processes',
      'Technology systems connected to finance operations',
    ],
    note: 'Best for teams handling sensitive records, remote work, and client-facing systems.',
    reverse: true,
  },
  {
    number: '05',
    title: 'Digital Marketing Services',
    href: '/services/digital-marketing-services',
    description:
      'Marketing should be practical, measurable, and connected to the business. We help clarify your message, organize campaigns, and improve follow-up systems.',
    bullets: [
      'Messaging and service-page guidance',
      'Lead-capture and follow-up workflows',
      'Email, CRM, and reporting coordination',
      'Campaign priorities reviewed through an ROI lens',
    ],
    note: 'Best for owners who want growth activity to feel disciplined instead of scattered.',
  },
  {
    number: '06',
    title: 'M&A Advisory',
    href: '/services/m-and-a-advisory',
    description:
      'Major transitions require clean records and calm guidance. We help owners prepare financial information for buying, selling, merging, or succession conversations.',
    bullets: [
      'Financial readiness and diligence support',
      'Revenue, margin, and cash flow narrative review',
      'Document-request and advisor coordination',
      'Owner decision support around timing and risk',
    ],
    note: 'Best for owners preparing for a transaction, transition, or outside review.',
    reverse: true,
  },
]

const steps = [
  ['01', 'Discovery', 'We start with a friendly conversation about your business, your goals, and where you need help.'],
  ['02', 'Plan', 'We create a tailored service plan that fits your needs and your budget: no upselling, no surprises.'],
  ['03', 'Execute', 'We handle the work with diligence and precision, keeping you informed every step of the way.'],
  ['04', 'Grow', 'We meet regularly to review progress, adjust strategy, and ensure your finances support your vision.'],
]
---

<PageShell active="services">
  <section class="py-20 sm:py-32">
    <div class="mx-auto max-w-5xl px-6">
      <h1 class="max-w-[18ch] text-balance font-serif text-4xl leading-tight tracking-tight text-cedar sm:text-6xl">
        Accounting, tax, advisory, and systems support built with conviction.
      </h1>
      <p class="text-pretty mt-6 max-w-[56ch] text-base leading-relaxed text-cedar/75 sm:text-lg">
        From monthly bookkeeping to tax strategy, CFO guidance, managed IT, marketing systems, and transaction readiness, we provide the practical infrastructure small business owners need to thrive.
      </p>
    </div>
  </section>

  <section class="border-y border-cedar/10 bg-cedar/5 py-24 sm:py-32">
    <div class="mx-auto max-w-5xl space-y-24 px-6">
      {services.map((service) => (
        <div class="grid items-start gap-12 sm:grid-cols-2">
          <div class={`space-y-6 ${service.reverse ? 'sm:order-2' : ''}`}>
            <span class="text-[10px] font-semibold uppercase tracking-widest text-moss">{service.number}</span>
            <h2 class="font-serif text-3xl text-cedar">{service.title}</h2>
            <p class="text-pretty text-base leading-relaxed text-cedar/75">{service.description}</p>
            <ul class="space-y-3 text-sm text-cedar/75">
              {service.bullets.map((item) => (
                <li class="flex items-start gap-3">
                  <span class="mt-1.5 block h-1 w-1 shrink-0 rounded-full bg-cedar"></span>
                  {item}
                </li>
              ))}
            </ul>
            <a href={service.href} class="inline-flex text-sm font-medium text-cedar underline underline-offset-4">Learn more</a>
          </div>
          <aside class={`rounded-2xl bg-sand p-8 ring-1 ring-cedar/10 ${service.reverse ? 'sm:order-1' : ''}`}>
            <div class="space-y-4">
              <p class="text-[10px] font-semibold uppercase tracking-widest text-moss">Client fit</p>
              <p class="font-serif text-xl italic text-cedar">{service.note}</p>
            </div>
          </aside>
        </div>
      ))}
    </div>
  </section>

  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-5xl px-6">
      <h2 class="mb-16 font-serif text-3xl text-cedar">How we work together</h2>
      <div class="grid gap-10 sm:grid-cols-4">
        {steps.map(([number, title, description]) => (
          <article class="space-y-4">
            <span class="font-serif text-4xl text-cedar/20">{number}</span>
            <h3 class="font-medium text-cedar">{title}</h3>
            <p class="text-pretty text-sm leading-relaxed text-cedar/75">{description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</PageShell>
