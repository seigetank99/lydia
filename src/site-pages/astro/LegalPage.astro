---
import PageHero from '../../components/astro/PageHero.astro'
import PageShell from '../../components/astro/PageShell.astro'

const { type } = Astro.props
const copy = {
  privacy: {
    eyebrow: 'Privacy Policy',
    title: 'Privacy and confidentiality matter.',
    paragraphs: [
      'This privacy policy is intended as website-facing draft language and should be reviewed by counsel before publication.',
      'Fidara may collect information that visitors voluntarily submit through forms, email, scheduling links, newsletter signups, or client intake workflows. This may include names, contact information, business information, service interests, messages, and documents shared by a visitor or client.',
      'Information may be used to respond to inquiries, evaluate whether Fidara is the right fit, provide services, improve website experience, coordinate onboarding, manage client relationships, and maintain business records.',
      'Fidara may use third-party tools for website hosting, forms, scheduling, analytics, document management, email, accounting, payroll, client communication, and related workflows. Final policy language should be reviewed against the actual tools in use.',
      'Visitors should not submit highly sensitive information, passwords, full account numbers, or full tax identification numbers through general website forms. Sensitive records should be shared only through approved secure workflows.',
      'Fidara takes confidentiality seriously, but no website transmission can be guaranteed completely secure. Clients should use approved portals or secure channels when sharing sensitive records.',
    ],
  },
  terms: {
    eyebrow: 'Terms of Use',
    title: 'Terms for using this website.',
    paragraphs: [
      'These terms are intended as website-facing draft language and should be reviewed by counsel before publication.',
      'The Fidara website is provided for general informational purposes. Website content may change without notice and may not reflect the latest legal, tax, accounting, technology, cybersecurity, or regulatory developments.',
      'Use of this website does not create a client relationship. A professional relationship begins only after Fidara accepts an engagement in writing.',
      'Visitors may not copy, misuse, interfere with, scrape, attack, reverse engineer, or attempt unauthorized access to the website, systems, forms, or client workflows.',
      'Third-party links or tools may be provided for convenience. Fidara is not responsible for third-party websites, services, or policies.',
      'Fidara may update, limit, suspend, or discontinue website content or functionality at any time.',
    ],
  },
  disclaimer: {
    eyebrow: 'Disclaimer',
    title: 'General information, not professional advice.',
    paragraphs: [
      'Website content is for general informational and educational purposes only.',
      'Nothing on this website is tax, legal, investment, cybersecurity, insurance, accounting, or financial advice for any specific person or business.',
      'Tax, accounting, payroll, advisory, technology, and business decisions depend on specific facts, location, timing, entity structure, records, and applicable rules.',
      'No professional relationship is formed by viewing this website, submitting a form, downloading a checklist, or reading educational content.',
      'Any service engagement must be separately reviewed, accepted, scoped, and documented in writing.',
      'Examples, checklists, articles, and tools are intended to help visitors organize questions and records. They should not be treated as a complete review of any tax, accounting, legal, technology, or compliance issue.',
    ],
  },
}[type]
---

<PageShell active="contact">
  <PageHero eyebrow={copy.eyebrow} title={copy.title} description="Website terms and informational legal language for Fidara. Review with counsel before launch." />

  <section class="border-t border-stone-200 px-8 py-12">
    <div class="mx-auto max-w-4xl rounded-xl border border-stone-200 bg-white/60 p-8 shadow-sm">
      {copy.paragraphs.map((paragraph) => (
        <p class="mb-5 text-base leading-8 text-slate-700 last:mb-0">{paragraph}</p>
      ))}
    </div>
  </section>
</PageShell>
