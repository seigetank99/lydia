---
import { taxResourcePages } from '../../components/site-core/data/index.jsx'
import PageHero from '../../components/astro/PageHero.astro'
import PageShell from '../../components/astro/PageShell.astro'
---

<PageShell active="resources">
  <PageHero
    eyebrow="Tax Resource Library"
    title="Tax organizers and planning guides for individuals and small business owners."
    description="Use these resources to gather documents, prepare questions, and understand what may need attention before tax season or year-end planning."
  />

  <section class="border-t border-stone-200 px-8 py-12">
    <div class="mx-auto grid max-w-6xl gap-5 md:grid-cols-2 lg:grid-cols-3">
      {taxResourcePages.map((page) => (
        <a href={`/tax-resources/${page.slug}`} class="rounded-xl border border-stone-200 bg-white/60 p-6 shadow-sm transition hover:-translate-y-1 hover:bg-white hover:shadow-md">
          <h2 class="font-serif text-3xl leading-tight text-slate-900">{page.title}</h2>
          <p class="mt-4 text-sm leading-7 text-slate-700">{page.description}</p>
          <span class="mt-5 inline-flex items-center gap-2 text-xs font-medium text-emerald-700">
            View guide <span aria-hidden="true">→</span>
          </span>
        </a>
      ))}
    </div>
  </section>
</PageShell>
