---
import { clientOnboardingDocuments } from '../../components/site-core/data/index.jsx'
import PageHero from '../../components/astro/PageHero.astro'
import PageShell from '../../components/astro/PageShell.astro'
import RelatedLinksSection from '../../components/astro/RelatedLinksSection.astro'
---

<PageShell active="resources">
  <PageHero eyebrow="Client Document Checklist" title="What to prepare before working with Fidara." description="A practical list of records that helps onboarding, bookkeeping cleanup, tax planning, payroll support, and advisory work move faster." />

  <section class="border-t border-stone-200 px-8 py-12">
    <div class="mx-auto grid max-w-6xl gap-5 md:grid-cols-2 lg:grid-cols-3">
      {clientOnboardingDocuments.map(([title, description]) => (
        <article class="rounded-xl border border-stone-200 bg-white/60 p-6 shadow-sm">
          <h2 class="font-serif text-3xl leading-tight text-slate-900">{title}</h2>
          <p class="mt-4 text-sm leading-7 text-slate-700">{description}</p>
        </article>
      ))}
    </div>
  </section>

  <RelatedLinksSection
    title="Helpful Next Steps"
    links={[
      ['Onboarding', '/onboarding'],
      ['Client Portal', '/client-portal'],
      ['Bookkeeping Cleanup', '/practice-areas/bookkeeping-cleanup'],
      ['Tax Resources', '/tax-resources'],
      ['Contact', '/contact'],
    ]}
  />
</PageShell>
