---
import { industryProfiles } from '../../components/site-core/data/index.jsx'
import PageHero from '../../components/astro/PageHero.astro'
import PageShell from '../../components/astro/PageShell.astro'
---

<PageShell active="sectors">
  <PageHero
    eyebrow="Industries"
    title="Focused pages for the industries people search for most."
    description="These pages support more specific client searches, from restaurants and dental practices to construction, real estate, and e-commerce."
  />

  <section class="border-t border-stone-200 px-8 py-12">
    <div class="mx-auto grid max-w-6xl gap-5 md:grid-cols-2 lg:grid-cols-3">
      {industryProfiles.map((profile) => (
        <a
          href={`/industries/${profile.slug}`}
          class="rounded-xl border border-stone-200 bg-white/60 p-6 shadow-sm transition hover:-translate-y-1 hover:bg-white hover:shadow-md"
        >
          <img src={profile.image} alt={profile.title} class="mb-4 h-16 w-16 object-contain mix-blend-multiply" />
          <h3 class="font-serif text-3xl leading-tight text-slate-900">{profile.title}</h3>
          <p class="mt-4 text-sm leading-7 text-slate-700">{profile.description}</p>
        </a>
      ))}
    </div>
  </section>
</PageShell>
