---
import Breadcrumbs from '../../components/astro/Breadcrumbs.astro'
import PageHero from '../../components/astro/PageHero.astro'
import PageShell from '../../components/astro/PageShell.astro'

const { page } = Astro.props
---

<PageShell active="resources">
  <Breadcrumbs items={[{ label: 'Tax Resources', href: '/tax-resources' }, { label: page.title }]} />

  <PageHero eyebrow="Tax Resource" title={page.title} description={page.description}>
    <div class="mt-8 flex flex-wrap gap-4">
      <a href="/contact" class="rounded-md bg-emerald-600 px-8 py-4 text-sm font-medium text-white transition hover:bg-emerald-700">
        Book a Consultation
      </a>
      <a href="/tax-resources" class="rounded-md border border-emerald-600 px-8 py-4 text-sm font-medium text-slate-900 transition hover:bg-white">
        All Tax Resources
      </a>
    </div>
  </PageHero>

  <section class="border-t border-stone-200 px-8 py-12">
    <div class="mx-auto grid max-w-6xl gap-5 md:grid-cols-3">
      {page.sections.map(([title, items]) => (
        <article class="rounded-xl border border-stone-200 bg-white/60 p-6 shadow-sm">
          <h2 class="font-serif text-3xl leading-tight text-slate-900">{title}</h2>
          <div class="mt-5 grid gap-3">
            {items.map((item) => (
              <div class="flex items-start gap-3">
                <span class="mt-0.5 h-5 w-5 flex-none text-emerald-600">✓</span>
                <p class="text-sm capitalize leading-6 text-slate-700">{item}</p>
              </div>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="border-t border-stone-200 px-8 py-10">
    <div class="mx-auto max-w-6xl rounded-xl border border-amber-200 bg-amber-50/70 p-5 text-sm leading-7 text-amber-950">
      <strong>Important:</strong> This guide is general educational information. Tax rules depend on your facts, location, entity type, records, and timing. Confirm your specific situation with a qualified tax professional.
    </div>
  </section>
</PageShell>
