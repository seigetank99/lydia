---
import PageShell from '../../components/astro/PageShell.astro'
import PageHero from '../../components/astro/PageHero.astro'
import IndustrySectorGrid from '../../components/astro/IndustrySectorGrid.astro'
---

<PageShell active="sectors">
  <PageHero
    eyebrow="Sectors We Support"
    title="Accounting, advisory, and systems support for service businesses, practices, shops, and growing teams."
    description="Explore the sectors Fidara supports and the operating patterns we help make clearer."
    backgroundImage="/images/sector.png"
  />

  <section class="border-t border-stone-200 px-8 py-12">
    <IndustrySectorGrid />
  </section>

  <section class="border-t border-stone-200 px-8 py-12">
    <div class="mx-auto max-w-6xl rounded-xl border border-stone-200 bg-white/60 p-8 shadow-sm">
      <div class="grid gap-8 md:grid-cols-[1fr_auto] md:items-center">
        <h2 class="font-serif text-4xl leading-tight text-slate-900">
          Don’t see your sector listed?
        </h2>
        <a href="/contact" class="inline-flex rounded-md bg-emerald-600 px-10 py-4 text-sm font-medium text-white transition hover:bg-emerald-700">
          Ask Fidara
        </a>
      </div>
    </div>
  </section>
</PageShell>
