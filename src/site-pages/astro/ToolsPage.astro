---
import { toolPages } from '../../components/site-core/data/index.jsx'
import PageHero from '../../components/astro/PageHero.astro'
import PageShell from '../../components/astro/PageShell.astro'
---

<PageShell active="resources">
  <PageHero
    eyebrow="Tools"
    title="Checklists and planning tools for cleaner operations."
    description="Use these practical tools to prepare for bookkeeping, payroll, tax season, managed IT, and better monthly reporting."
  />

  <section class="border-t border-stone-200 px-8 py-12">
    <div class="mx-auto grid max-w-6xl gap-5 md:grid-cols-2 lg:grid-cols-3">
      {toolPages.map((tool) => (
        <a
          href={`/tools/${tool.slug}`}
          class="rounded-xl border border-stone-200 bg-white/60 p-6 shadow-sm transition hover:-translate-y-1 hover:bg-white hover:shadow-md"
        >
          <h3 class="font-serif text-3xl leading-tight text-slate-900">{tool.title}</h3>
          <p class="mt-4 text-sm leading-7 text-slate-700">{tool.description}</p>
        </a>
      ))}
    </div>
  </section>
</PageShell>
