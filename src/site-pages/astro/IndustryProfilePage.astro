---
import { serviceBySlug } from '../../components/site-core/data/index.jsx'
import PageHero from '../../components/astro/PageHero.astro'
import PageShell from '../../components/astro/PageShell.astro'
import ServiceCard from '../../components/astro/ServiceCard.astro'

const { profile } = Astro.props
const recommended = profile.recommendedServices.map((slug) => serviceBySlug[slug]).filter(Boolean)
---

<PageShell active="sectors">
  <PageHero eyebrow="Industry Support" title={profile.title} description={profile.description}>
    <div class="mt-8 flex flex-wrap gap-4">
      <a href="/contact" class="rounded-md bg-emerald-600 px-8 py-4 text-sm font-medium text-white transition hover:bg-emerald-700">
        Start the Conversation
      </a>
      <a href="/industries" class="rounded-md border border-emerald-600 px-8 py-4 text-sm font-medium text-slate-900 transition hover:bg-white">
        All Industries
      </a>
    </div>
  </PageHero>

  <section class="border-t border-stone-200 px-8 py-12">
    <div class="mx-auto grid max-w-6xl gap-10 md:grid-cols-[0.85fr_1.15fr]">
      <div>
        <img src={profile.image} alt={profile.title} class="h-32 w-32 object-contain mix-blend-multiply" />
        <h2 class="mt-6 font-serif text-4xl leading-tight text-slate-900">What Fidara focuses on.</h2>
      </div>
      <div class="grid gap-4">
        {profile.priorities.map((priority) => (
          <div class="flex items-start gap-4 border-b border-stone-200 pb-4 last:border-b-0">
            <span class="mt-1 h-5 w-5 flex-none text-emerald-600">✓</span>
            <p class="text-base leading-7 text-slate-800">{priority}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="border-t border-stone-200 px-8 py-12">
    <h2 class="mx-auto max-w-6xl font-serif text-3xl leading-tight text-slate-900">Recommended Services</h2>
    <div class="mx-auto mt-6 grid max-w-6xl gap-4 sm:grid-cols-2 lg:grid-cols-5">
      {recommended.map((service) => <ServiceCard {...service} />)}
    </div>
  </section>
</PageShell>
